# This file belongs in docker/.env (next to docker-compose.yml).
# Copy it there: cp .env.example docker/.env

# MCP server binding
MEM_HOST=127.0.0.1
MEM_PORT=7333

# Docker volume: where repos live on this machine.
# macOS Docker Desktop: set to /Users  (default shared path)
# Linux: set to /home or /
# The path is bind-mounted read-only into the MCP container at the same path.
REPOS_ROOT=/Users

# Embedding models (Ollama model names)
# nomic-embed-text works well for both code and memory and is available in Ollama.
# Switch to a code-specific model later if needed (e.g. after benchmarking).
CODE_EMBED_MODEL=nomic-embed-text
MEMORY_EMBED_MODEL=nomic-embed-text

# Vector index dimension (fixed at creation — increase requires index rebuild)
MAX_DIM=2048
