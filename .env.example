# Copy to .env at the repo root: cp .env.example .env

# MCP server binding
MEM_HOST=127.0.0.1
MEM_PORT=7333

# Docker volume: where repos live on this machine.
# macOS Docker Desktop: set to /Users  (default shared path)
# Linux: set to /home or /
# The path is bind-mounted read-only into the MCP container at the same path.
REPOS_ROOT=/Users

# Embedding models (HuggingFace model IDs, loaded via SentenceTransformers)
CODE_EMBED_MODEL=microsoft/graphcodebert-base
MEMORY_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# Vector index dimension (fixed at creation — changing requires reindex)
MAX_DIM=2048
